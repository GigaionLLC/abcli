# --- SECRETS — NEVER COMMIT (production Apple Business API + VPP) ---
.env
secrets/
*.pem
*.p12
*.key
*.vpptoken
*.token
token-cache.json

# --- local operational notes (agent handoffs, scratch) — NEVER COMMIT ---
*.local.md

# --- Go build artifacts ---
/bin/
*.test
/abctl

# --- gitops tree (generated by `abctl seed`) ---
# Seeded profiles can carry secrets (auth headers, Wi-Fi passwords, certs), so the
# generated tree is ignored by default so nothing sensitive is committed by accident.
# Un-ignore it deliberately once you adopt gitops/ as your committed source of truth.
/gitops/
