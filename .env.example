# Apple Business API — config template. Copy to .env (gitignored) and fill in.
# Keep the real values only in .env or your team's secret manager — never commit them.

# --- OAuth client (Apple Business > Settings > API account) ---
AB_CLIENT_ID=BUSINESSAPI.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# No Key ID is needed — the client-assertion JWT omits `kid` (a kid -> 400 invalid_client).
AB_PRIVATE_KEY=secrets/key.pem       # unencrypted EC P-256: SEC1 (BEGIN EC PRIVATE KEY) or PKCS#8 (BEGIN PRIVATE KEY)

# --- Endpoints / scope (do not change unless Apple does) ---
AB_SCOPE=business.api
AB_TOKEN_URL=https://account.apple.com/auth/oauth2/token
AB_TOKEN_AUD=https://account.apple.com/auth/oauth2/v2/token   # JWT `aud` MUST be the /v2/token form
AB_API_BASE=https://api-business.apple.com/v1/

# --- VPP / Apps and Books (optional; only if using licensed-app automation) ---
AB_VPP_TOKEN=secrets/vpp_stoken.vpptoken
AB_VPP_EXP=YYYY-MM-DDThh:mm:ss+0000
AB_ORG_NAME=Your Org Name
